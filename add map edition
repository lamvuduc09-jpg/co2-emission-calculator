<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Green Logistics CO₂ Calculator</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>
  <style>
    body { font-family: Arial; margin: 0; background: #eef6f1; }
    .box { max-width: 1000px; margin: 20px auto; background: white; padding: 20px; border-radius: 15px; }
    h1 { color: #167247; text-align: center; }
    #map { height: 400px; border-radius: 12px; margin-bottom: 20px; }
    label { font-weight: bold; display: block; margin-top: 10px; }
    input, select, button {
      width: 100%; padding: 10px; margin-top: 5px;
      border-radius: 8px; border: 1px solid #ccc;
    }
    button {
      background: #167247; color: white; font-size: 16px; cursor: pointer;
      margin-top: 15px;
    }
    .result {
      background: #e6f5ec; padding: 15px; margin-top: 20px;
      border-radius: 10px; display: none;
    }
  </style>
</head>
<body>

<div class="box">
  <h1>Green Logistics CO₂ Calculator</h1>

  <p><b>Hướng dẫn:</b> Click 2 điểm trên bản đồ: điểm đi và điểm đến.</p>

  <div id="map"></div>

  <label>Quãng đường ước tính (km)</label>
  <input type="number" id="distance" readonly>

  <label>Khối lượng hàng hóa (tấn)</label>
  <input type="number" id="weight" placeholder="Ví dụ: 20">

  <label>Phương thức vận tải</label>
  <select id="mode">
    <option value="0.08">Đường bộ - Xe tải</option>
    <option value="0.03">Đường sắt</option>
    <option value="0.02">Đường thủy nội địa</option>
    <option value="0.01">Đường biển</option>
    <option value="0.50">Hàng không</option>
  </select>

  <button onclick="calculateCO2()">Tính CO₂</button>
  <button onclick="resetMap()">Chọn lại điểm</button>

  <div class="result" id="result">
    <h2>Kết quả</h2>
    <p><b>Khoảng cách:</b> <span id="rDistance"></span> km</p>
    <p><b>Khối lượng:</b> <span id="rWeight"></span> tấn</p>
    <p><b>Lượng CO₂:</b> <span id="rCO2"></span> kg CO₂</p>
    <p><b>Đánh giá:</b> <span id="rating"></span></p>
  </div>
</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
  let map = L.map('map').setView([20.8449, 106.6881], 8); // Hải Phòng
  let points = [];
  let markers = [];
  let line;

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© OpenStreetMap'
  }).addTo(map);

  map.on('click', function(e) {
    if (points.length >= 2) return;

    points.push(e.latlng);
    let marker = L.marker(e.latlng).addTo(map);
    markers.push(marker);

    if (points.length === 2) {
      line = L.polyline(points, { color: 'green' }).addTo(map);
      let distance = map.distance(points[0], points[1]) / 1000;
      document.getElementById("distance").value = distance.toFixed(2);
    }
  });

  function calculateCO2() {
    let distance = Number(document.getElementById("distance").value);
    let weight = Number(document.getElementById("weight").value);
    let factor = Number(document.getElementById("mode").value);

    if (distance <= 0 || weight <= 0) {
      alert("Vui lòng chọn 2 điểm trên bản đồ và nhập khối lượng hàng.");
      return;
    }

    let co2 = distance * weight * factor;

    let rating = "";
    if (co2 < 100) {
      rating = "A - Phát thải thấp";
    } else if (co2 < 500) {
      rating = "B - Phát thải trung bình";
    } else {
      rating = "C - Phát thải cao";
    }

    document.getElementById("rDistance").innerText = distance.toFixed(2);
    document.getElementById("rWeight").innerText = weight;
    document.getElementById("rCO2").innerText = co2.toFixed(2);
    document.getElementById("rating").innerText = rating;
    document.getElementById("result").style.display = "block";
  }

  function resetMap() {
    points = [];
    markers.forEach(m => map.removeLayer(m));
    markers = [];

    if (line) {
      map.removeLayer(line);
      line = null;
    }

    document.getElementById("distance").value = "";
    document.getElementById("result").style.display = "none";
  }
</script>

</body>
</html>
